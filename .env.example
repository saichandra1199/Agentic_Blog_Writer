# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# ── Images (pick one — priority: Unsplash > Pexels > Picsum fallback) ─────────
# Unsplash: free 50 req/hour → unsplash.com/developers → "New Application"
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Pexels: free 200 req/hour → pexels.com/api → Get Started
PEXELS_API_KEY=your_pexels_api_key_here

# ── GIFs ──────────────────────────────────────────────────────────────────────
# Giphy: free dev key → developers.giphy.com → Create an App
# Without this key, a curated fallback GIF set is used automatically
GIPHY_API_KEY=your_giphy_api_key_here
